#!/bin/bash

set -e

WORKDIR=$(realpath $PWD)
VAGRANT_CWD=${VAGRANT_CWD:-$WORKDIR}
VAGRANTLIBVIRT_IMAGE=${VAGRANTLIBVIRT_IMAGE:-'vagrantlibvirt/vagrant-libvirt:latest'}
VAGRANTLIBVIRT_NETWORK=${VAGRANTLIBVIRT_NETWORK:-'host'}

export LIBVIRT_DEFAULT_URI=${LIBVIRT_DEFAULT_URI:-qemu:///system}
export IGNORE_MISSING_LIBVIRT_SOCK=${IGNORE_MISSING_LIBVIRT_SOCK:-1}

CONTAINER_EXPORT_ENVS=(
  LIBVIRT_DEFAULT_URI
  IGNORE_MISSING_LIBVIRT_SOCK
  VAGRANT_VAGRANTFILE
  VAGRANT_CWD
)
CONTAINER_EXPORT_ENVS+=($(env | grep '^VAGRANT_' | cut -d'=' -f1))

CONTAINER_ENV_ARGS=()
declare -A SEEN
for ENVVAR in "${CONTAINER_EXPORT_ENVS[@]}"; do
  SEEN[$ENVVAR]=1
done
for ENVVAR in "${!SEEN[@]}"; do
  CONTAINER_ENV_ARGS+=(-e "${ENVVAR}")
done

DOCKER_RUN_SHELL_OPT=()
if [[ -t 0 && -t 1 ]]; then
  # STDOUT to a terminal, not piped
  DOCKER_RUN_SHELL_OPT=(-i -t)
fi

CMD_BIN='docker'
CMD_ARGS=(
  run --rm \
  "${DOCKER_RUN_SHELL_OPT[@]}" \
  "${CONTAINER_ENV_ARGS[@]}" \
  -v /var/run/libvirt/:/var/run/libvirt/ \
  -v "${HOME}/.vagrant.d:/.vagrant.d" \
  -v "${VAGRANT_CWD}":"${VAGRANT_CWD}" \
  -v "${WORKDIR}":"${WORKDIR}" \
  -w "${WORKDIR}" \
  --network "${VAGRANTLIBVIRT_NETWORK}" \
  "${VAGRANTLIBVIRT_IMAGE}" vagrant $@
)
"${CMD_BIN}" "${CMD_ARGS[@]}"
